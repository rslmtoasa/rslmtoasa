&calculation
!pre_processing = 'bravais'
post_processing = 'conductivity'
verbose = T
/
&lattice
rc = 060
alat = 3.9264951876
crystal_sym = 'fcc'
wav = 1.5344598728
pbc = .true.
b1 = .false.
b2 = .false.
b3 = .false.
n1 = 20
n2 = 20
n3 = 20
ntype = 1
ct(1) = 4.0d0
r2 = 16.0d0
/
&atoms
database = './'
label(1) = 'Pt'
/
&self
ws_all = .true.
nstep = 1
/
&hamiltonian
v_alpha = 0, 1, 0
v_beta =  1, 0, 0
js_alpha = 'z'
/
&energy
fermi = -0.085837
energy_min = -1.0
energy_max = 1.2
channels_ldos = 2500
/
&control
calctype = 'B'
nsp = 2
cond_ll = 50
lld = 50
recur = 'chebyshev'
cond_type = 'spin'
cond_calctype = 'per_type'
/
&mix
mixtype = 'broyden'
beta = 0.4
/
&hamiltonian
hoh = false
/
