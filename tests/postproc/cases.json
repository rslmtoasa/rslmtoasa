      "timeout": 600,
      "namelists": {
        "control":     { "nsp": 2, "recur": "chebyshev", "lld": 50 },
        "self":        { "nstep": 1 },
        "hamiltonian": { "hoh": true }
      },
      "checks": {
        "text": [
          { "file": "totaldos.out", "rows": [500, 1000, 1500], "cols": [1, 2] }
