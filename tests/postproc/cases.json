      "namelists": {
        "control":     { "nsp": 2, "recur": "chebyshev", "lld": 100 },
        "self":        { "nstep": 1 },
        "hamiltonian": { "hoh": false }
      },
      "checks": {
        "text": [
          { "file": "totaldos.out", "rows": [500, 1000, 1500], "cols": [1, 2] }
        ],
        "text": [
          { "file": "Pt_cond.out", "rows": [500, 1000, 1500], "cols": [1, 2] }
        ]
      }
    },
    {
      "name": "Example_exchange_conductivity_fccPt_hoh",
